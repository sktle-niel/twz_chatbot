# Anthropic (Claude) — get from https://platform.claude.com
ANTHROPIC_API_KEY=sk-ant-...

# Loyverse — Back Office > Integrations > Access tokens (same account as FWZ)
LOYVERSE_ACCESS_TOKEN=your-loyverse-token
# This bot answers for ALL stores EXCEPT the ones listed here (comma-separated)
LOYVERSE_EXCLUDE_STORES=FOUR WHEELS ZONE
# Optional allowlist instead: comma-separated store names to include
# LOYVERSE_STORE_NAMES=ROXAS BRANCH,TAYTAY BRANCH

# Brand name the bot uses when talking to customers
BOT_STORE_NAME=TWO WHEELS ZONE

# Meta Messenger — from the TWZ app in developers.facebook.com
PAGE_ACCESS_TOKEN=your-page-access-token
# Any random string you invent; must match what you type in the Meta webhook setup form
VERIFY_TOKEN=my-secret-verify-token
# App Dashboard > App settings > Basic > App secret — used to verify that
# webhook calls really come from Meta (recommended in production)
APP_SECRET=your-app-secret

PORT=3001
